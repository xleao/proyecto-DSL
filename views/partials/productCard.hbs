<article class="product-card">
    <a href="/producto/{{_id}}" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; flex: 1;">
        <div class="product-image-container">
            {{#if isNewArrival}}
                <span class="badge new">{{t 'product.new'}}</span>
            {{/if}}
            <img src="{{imageUrl}}" alt="{{translate nameKey}}" class="product-image" loading="lazy" onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?q=80&w=600&auto=format&fit=crop';">
        </div>
        
        <div class="product-info">
            <h3 class="product-name">{{translate nameKey}}</h3>
            {{{renderStars rating}}}
            <p class="product-price">{{formatCurrency price}}</p>
            
        </div>
    </a>
    
    <div class="product-actions">
        <select id="size-{{_id}}" class="size-dropdown">
            {{#each sizes}}
                <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
        <input type="number" id="qty-{{_id}}" class="quantity-input" min="1" value="1" style="width: 50px; padding: 10px; border: 1px solid #ccc; font-family: inherit; font-size: 1rem; text-align: center; border-radius:0;">
        <button class="btn-add-cart" onclick="addToCartWithDropdown('{{_id}}', '{{translate nameKey}}', {{price}}, '{{imageUrl}}')">
            <i class="fa-solid fa-cart-plus"></i> {{t 'product.add'}}
        </button>
    </div>
</article>
