<header class="hero" style="height: 40vh; background-position: top;">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 style="font-size: 3rem;">{{categoryTitle}}</h1>
    </div>
</header>

<section class="catalog-section" style="padding-top: 4rem;">
    <div class="product-grid">
        {{#each products}}
            {{> productCard }}
        {{else}}
            <p style="text-align:center; grid-column: 1 / -1;">No hay productos en esta categoría.</p>
        {{/each}}
    </div>
</section>
